// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * User model representing application users. Each user can have multiple playlists.
 */

enum UserStatus {
  ACTIVE
  PENDING
  BANNED
}
model User {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  email     String     @unique
  isActive  Boolean    @map("is_active") @default(false)
  status    UserStatus @default(ACTIVE)
  playlists Playlist[]
  roles     UserRole[]
  refreshTokens RefreshToken[]

  createdAt DateTime   @map("created_at") @default(now())
  createdBy String?    @map("created_by")
  updatedAt DateTime   @map("updated_at") @default(now())
  updatedBy String?    @map("updated_by")
  deletedAt DateTime?  @map("deleted_at")
  deletedBy String?    @map("deleted_by")

  @@map("users")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

enum RoleName {
  USER
  CREATOR
  ADMIN
}
model Role {
  id          String   @id @default(uuid())
  name        RoleName
  users       UserRole[]
  permissions RolePermission[]
  
  createdAt DateTime @map("created_at") @default(now())
  createdBy String?  @map("created_by")
  updatedAt DateTime @map("updated_at") @default(now())
  updatedBy String?  @map("updated_by")
  deletedAt    DateTime?  @map("deleted_at")
  deletedBy    String?    @map("deleted_by")

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  name      String
  roles     RolePermission[]
  
  createdAt DateTime @map("created_at") @default(now())
  createdBy String?  @map("created_by")
  updatedAt DateTime @map("updated_at") @default(now())
  updatedBy String?  @map("updated_by")
  deletedAt    DateTime?  @map("deleted_at")
  deletedBy    String?    @map("deleted_by")

  @@map("permissions")
}

model RolePermission {
  role       Role       @relation(fields: [roleId], references: [id])
  roleId     String     @map("role_id")
  permission Permission @relation(fields: [permissionId], references: [id])
  permissionId String   @map("permission_id")

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @map("token_hash") @unique
  userId     String   @map("user_id")
  expiryTime Int      @map("expiry_time")
  deviceId   String?  @map("device_id")
  isRevoked  Boolean  @map("is_revoked") @default(false)

  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @map("created_at") @default(now())
  createdBy String?  @map("created_by")
  updatedAt DateTime @map("updated_at") @default(now())
  updatedBy String?  @map("updated_by")

  @@map("refresh_tokens")
}

/**
 * Song model representing individual songs. 
 * Each song can belong to multiple playlists.
 */
model Song {
  id           String        @id @default(uuid())
  title        String        
  artist       String
  audioUrl     String       @map("audio_url")
  thumbnailUrl String?      @map("thumbnail_url")
  duration     Int?         // Song duration (ms)
  playlists    PlaylistSong[] // Many-to-Many relationship with Playlist

  createdAt    DateTime   @map("created_at") @default(now())
  createdBy    String?    @map("created_by")
  updatedAt    DateTime   @map("updated_at") @default(now())
  updatedBy    String?    @map("updated_by")
  deletedAt    DateTime?  @map("deleted_at")
  deletedBy    String?    @map("deleted_by")

  @@map("songs")
}

/**
 * Playlist model representing user-created playlists. Each playlist belongs to a single user.
 */
model Playlist {
  id        String   @id @default(uuid())
  name      String
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @map("user_id")
  songs     PlaylistSong[]

  createdAt DateTime @map("created_at") @default(now())
  createdBy String?  @map("created_by")
  updatedAt DateTime @map("updated_at") @default(now())
  updatedBy String?  @map("updated_by")
  deletedAt DateTime?  @map("deleted_at")
  deletedBy String?    @map("deleted_by")

  @@map("playlists")
}


/**
 * Join table for the many-to-many relationship between Playlist and Song.
 */
model PlaylistSong {
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  playlistId String   @map("playlist_id")
  song       Song     @relation(fields: [songId], references: [id])
  songId     String   @map("song_id")

  createdAt DateTime @map("created_at") @default(now())
  createdBy String?  @map("created_by")
  updatedAt DateTime @map("updated_at") @default(now())
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")

  @@id([playlistId, songId])
  @@map("playlist_songs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
/**
 * Job model representing background jobs for processing tasks.
 */
model Job {
  id           String    @id @default(uuid())
  actionType   String    @map("action_type")
  status       JobStatus @default(PENDING)
  payload      Json

  // Tracking process
  currentStep  Int       @default(0) @map("current_step")
  maxStep      Int       @default(1) @map("max_step")

  errorMessage String?   @db.Text @map("error_message")
  userId       String    @map("user_id")

  createdAt DateTime @map("created_at") @default(now())
  updatedAt DateTime @map("updated_at") @default(now())

  @@map("jobs")
  @@index([userId])
  @@index([status])
}